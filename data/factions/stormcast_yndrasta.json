  "regiment_abilities": [
    {
      "name": "Drive Them Back",
      "description": "Pick any number of friendly units that are both contesting an objective and in combat. Each can make a pile-in move. For each unit that did so, roll a dice; on a 4+, inflict 1 mortal damage on an enemy unit within 1\".",
      "timing": "end_of_any_turn",
      "effect": {
        "type": "mortal_damage_on_condition",
        "roll_required": 4,
        "damage": 1,
        "condition": "contesting_objective_and_in_combat"
      }
    },
    {
      "name": "Defend to the Last",
      "description": "Friendly units have Ward (6+) while they are contesting an objective you control.",
