  "battle_traits": [
    {
      "name": "The Lurking Vermintide",
      "description": "Pick a friendly unit that has not been deployed to be the target. The target unit is set up in reserve in the tunnels below. Units in the tunnels below that have not used the 'Gnawhole Ambush' ability by the end of the third battle round are destroyed.",
      "timing": "once_per_battle_deployment_phase",
      "declare": "Pick a friendly unit that has not been deployed to be the target.",
      "keywords": ["Deploy"],
      "sub_abilities": [
        {
          "name": "Gnawhole Ambush",
          "description": "Set up that unit wholly within 6\" of a corner of the battlefield and more than 9\" from all enemy units.",
          "timing": "your_movement_phase",
          "declare": "Pick a friendly unit that is in the tunnels below to use this ability.",
          "keywords": ["Core"],
          "effect": {
            "type": "deployment",
            "condition": "unit_in_tunnels_below",
            "setup": "wholly_within_6_of_corner_more_than_9_from_enemies"
          }
        }
      ]
    }
  ],
  "regiment_abilities": [
    {
      "name": "Warpstone-Laced Bullets",
      "description": "That weapon has Crit (Mortal) this phase.",
      "timing": "once_per_battle_your_shooting_phase",
      "declare": "Pick a ranged weapon a friendly unit is armed with.",
      "effect": {
        "type": "weapon_buff",
        "modifier": "add_ability",
        "ability": "Crit (Mortal)",
        "target_weapon_type": "ranged",
        "duration": "this_phase"
