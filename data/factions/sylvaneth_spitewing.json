    {
      "name": "Song of the Hunt",
      "description": "Gain 1 chord each time an enemy quarry is destroyed. 1 chord: +1 run/charge rolls for friendly units within 9\" of quarry. 2 chords: +1 hit rolls for friendly units' attacks within 9\" of quarry. 3+ chords: +1 wound rolls for friendly units' attacks within 9\" of quarry.",
      "timing": "passive",
      "effect": {
        "type": "progressive_buff",
        "chords": [
          {
            "required": 1,
            "type": "movement_buff",
            "modifier": "run_charge_bonus",
            "value": 1,
            "scope": "friendly_units_within_9_of_quarry"
          },
          {
            "required": 2,
            "type": "friendly_buff",
            "modifier": "hit_bonus",
            "value": 1,
            "scope": "friendly_units_within_9_of_quarry"
          },
          {
            "required": 3,
            "type": "friendly_buff",
            "modifier": "wound_bonus",
            "value": 1,
            "scope": "friendly_units_within_9_of_quarry"
          }
        ]
      }
    },
    {
      "name": "Target of Vengeance",
      "description": "If there is no enemy quarry on the battlefield, pick an enemy unit to be the quarry for the rest of the battle.",
      "timing": "once_per_battle_round_start_of_battle_round",
      "effect": {
        "type": "mark_quarry",
        "applies_to": "enemy_unit"
      }
